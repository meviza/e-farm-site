---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/sections/Hero.astro";
import Problem from "../../components/sections/Problem.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import Technology from "../../components/sections/Technology.astro";
import AISection from "../../components/sections/AISection.astro";
import Specs from "../../components/sections/Specs.astro";
import BMS from "../../components/sections/BMS.astro";
import Chassis from "../../components/sections/Chassis.astro";
import Market from "../../components/sections/Market.astro";
import Competitors from "../../components/sections/Competitors.astro";
import References from "../../components/sections/References.astro";
import Team from "../../components/sections/Team.astro";
import Roadmap from "../../components/sections/Roadmap.astro";
import Tiers from "../../components/sections/Tiers.astro";
import Resources from "../../components/sections/Resources.astro";
import Faq from "../../components/sections/Faq.astro";
import Reservation from "../../components/sections/Reservation.astro";
import Footer from "../../components/sections/Footer.astro";
import { useTranslations, type Lang } from "../../i18n/ui";

// English lives at the root (/), so only emit the six prefixed locales here.
export function getStaticPaths() {
  return ["de", "fr", "es", "it", "nl", "tr"].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const title = `E-Farm — ${t("hero.badge")}`;
const description = t("hero.subtitle");
---

<BaseLayout lang={lang} title={title} description={description}>
  <Nav lang={lang} />
  <main id="main">
    <Hero lang={lang} />
    <Problem lang={lang} />
    <HowItWorks lang={lang} />
    <Technology lang={lang} />
    <AISection lang={lang} />
    <Specs lang={lang} />
    <BMS lang={lang} />
    <Chassis lang={lang} />
    <Market lang={lang} />
    <Competitors lang={lang} />
    <References lang={lang} />
    <Team lang={lang} />
    <Roadmap lang={lang} />
    <Tiers lang={lang} />
    <Resources lang={lang} />
    <Faq lang={lang} />
    <Reservation lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
