---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";
import { roadmap } from "../../data/roadmap";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="border-b border-border bg-bg">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("roadmap.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("roadmap.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("roadmap.lead")}</p>
    </Reveal>

    <ol class="relative mt-12 border-l border-border pl-8">
      {
        roadmap.map((m, i) => (
          <Reveal client:visible delay={i * 0.05}>
            <li class="relative pb-10 last:pb-0">
              <span
                class={`absolute -left-[37px] flex h-4 w-4 items-center justify-center rounded-full border-2 ${
                  m.target ? "border-accent bg-bg" : "border-brand bg-brand"
                }`}
                aria-hidden="true"
              />
              <div class="flex flex-wrap items-center gap-3">
                <span class="font-mono text-sm font-semibold text-brand">{m.year}</span>
                <h3 class="text-lg font-semibold tracking-tight">{m.title}</h3>
                {m.target && (
                  <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-accent">
                    {t("roadmap.targetBadge")}
                  </span>
                )}
              </div>
              <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">{m.description}</p>
            </li>
          </Reveal>
        ))
      }
    </ol>
  </div>
</section>
