---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="border-b border-border bg-bg-elevated">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("ai.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("ai.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("ai.lead")}</p>
    </Reveal>

    <div class="mt-12 grid items-start gap-8 lg:grid-cols-2">
      <Reveal client:visible>
        <!-- Annotated detection mock -->
        <figure class="overflow-hidden rounded-2xl border border-border bg-surface shadow-[var(--shadow)]">
          <div class="relative aspect-[4/3] bg-surface-2 bg-grid">
            <!-- ripe detection box -->
            <div class="absolute left-[22%] top-[30%] h-[26%] w-[24%] rounded-md border-2 border-brand">
              <span class="absolute -top-6 left-0 rounded bg-brand px-1.5 py-0.5 font-mono text-[10px] font-semibold text-white">
                {t("ai.boxLabel")}
              </span>
              <span class="absolute inset-0 flex items-center justify-center text-3xl">🍓</span>
            </div>
            <!-- unripe detection box -->
            <div class="absolute right-[20%] top-[48%] h-[22%] w-[20%] rounded-md border-2 border-accent border-dashed">
              <span class="absolute -top-6 left-0 rounded bg-accent px-1.5 py-0.5 font-mono text-[10px] font-semibold text-[#0d1912]">
                {t("ai.boxLabelAlt")}
              </span>
              <span class="absolute inset-0 flex items-center justify-center text-2xl opacity-70">🍓</span>
            </div>
          </div>
          <figcaption class="border-t border-border px-4 py-3 font-mono text-xs text-muted">
            {t("ai.mockCaption")}
          </figcaption>
        </figure>
      </Reveal>

      <div class="space-y-5">
        <Reveal client:visible>
          <div class="rounded-2xl border border-brand bg-brand-soft p-6 shadow-[var(--shadow)]">
            <h3 class="text-base font-semibold text-brand-strong">{t("ai.claimTitle")}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text">{t("ai.claimBody")}</p>
          </div>
        </Reveal>
        <Reveal client:visible delay={0.08}>
          <div class="rounded-2xl border border-border bg-surface p-6 shadow-[var(--shadow)]">
            <h3 class="text-base font-semibold text-text">{t("ai.contextTitle")}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{t("ai.contextBody")}</p>
            <a href="#references" class="mt-3 inline-flex text-sm font-semibold text-brand hover:text-brand-strong">
              {t("ai.contextLink")} →
            </a>
          </div>
        </Reveal>
      </div>
    </div>
  </div>
</section>
