---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const heroImg = `${base}/images/renders/hero.webp`;
const backerkit = "https://backerkit.com";

const chips = [
  t("hero.chips.accuracy"),
  t("hero.chips.images"),
  t("hero.chips.crops"),
  t("hero.chips.precision"),
  t("hero.chips.open"),
];
---

<section class="relative overflow-hidden border-b border-border bg-bg">
  <div class="bg-grid pointer-events-none absolute inset-0 opacity-70"></div>
  <div
    class="pointer-events-none absolute -top-40 left-1/2 h-96 w-[48rem] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:gap-8 lg:px-8 lg:py-28">
    <Reveal client:load>
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-muted"
        >
          <span class="h-2 w-2 rounded-full bg-brand"></span>
          {t("hero.badge")}
        </span>
        <h1 class="mt-5 text-4xl font-extrabold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
          {t("hero.titleLead")} <span class="text-gradient">{t("hero.titleHighlight")}</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
          {t("hero.subtitle")}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={backerkit}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white shadow-[var(--shadow)] transition-colors hover:bg-brand-strong focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          >
            {t("hero.ctaPrimary")}
          </a>
          <a
            href="#reserve"
            class="inline-flex items-center justify-center rounded-lg border border-border bg-surface px-6 py-3 text-sm font-semibold text-text transition-colors hover:bg-surface-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
          >
            {t("hero.ctaSecondary")}
          </a>
        </div>
        <ul class="mt-8 flex flex-wrap gap-2">
          {
            chips.map((c) => (
              <li class="rounded-full border border-border bg-surface px-3 py-1 font-mono text-xs text-muted">
                {c}
              </li>
            ))
          }
        </ul>
      </div>
    </Reveal>

    <Reveal client:load delay={0.15}>
      <div class="relative">
        <div
          class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-border bg-surface-2 shadow-[var(--shadow)]"
        >
          {/* If a real render is added at public/images/renders/hero.webp it is shown;
              otherwise the bespoke vector scene below is used. */}
          <img
            src={heroImg}
            alt={t("hero.imageAlt")}
            loading="eager"
            class="absolute inset-0 z-10 h-full w-full object-cover"
            onerror="this.remove();"
          />
          <svg
            viewBox="0 0 800 600"
            role="img"
            aria-label={t("hero.imageAlt")}
            class="h-full w-full"
            preserveAspectRatio="xMidYMid slice"
          >
            <defs>
              <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--brand-soft)"></stop>
                <stop offset="100%" stop-color="var(--surface-2)"></stop>
              </linearGradient>
            </defs>
            <rect width="800" height="600" fill="url(#sky)"></rect>
            {/* greenhouse roof trusses */}
            <g stroke="var(--border)" stroke-width="2" fill="none" opacity="0.9">
              <path d="M0 150 L160 60 L320 150 M320 150 L480 60 L640 150 M640 150 L800 60"></path>
              <path d="M40 150 L40 30 M240 150 L240 30 M440 150 L440 30 M640 150 L640 30"
                opacity="0.4"></path>
              <line x1="0" y1="150" x2="800" y2="150"></line>
            </g>
            {/* ground */}
            <line x1="0" y1="472" x2="800" y2="472" stroke="var(--border)" stroke-width="2"></line>
            {/* back plant row (right) with tomato clusters */}
            <g>
              <rect x="600" y="300" width="14" height="172" rx="7" fill="var(--brand-strong)"></rect>
              <g fill="var(--brand)">
                <ellipse cx="585" cy="330" rx="34" ry="20"></ellipse>
                <ellipse cx="630" cy="360" rx="38" ry="22"></ellipse>
                <ellipse cx="600" cy="405" rx="40" ry="24"></ellipse>
              </g>
              <g fill="#e4572e">
                <circle cx="612" cy="352" r="11"></circle>
                <circle cx="588" cy="392" r="11"></circle>
                <circle cx="636" cy="392" r="10"></circle>
              </g>
            </g>
            {/* left plant row (background, soft) */}
            <g opacity="0.55">
              <rect x="110" y="330" width="12" height="142" rx="6" fill="var(--brand-strong)"></rect>
              <ellipse cx="116" cy="360" rx="40" ry="24" fill="var(--brand)"></ellipse>
              <ellipse cx="116" cy="408" rx="44" ry="26" fill="var(--brand)"></ellipse>
              <circle cx="98" cy="372" r="9" fill="#e4572e"></circle>
              <circle cx="134" cy="404" r="9" fill="#e4572e"></circle>
            </g>
            {/* ROBOT */}
            <g>
              {/* wheels */}
              <circle cx="300" cy="468" r="26" fill="var(--text)"></circle>
              <circle cx="300" cy="468" r="11" fill="var(--surface)"></circle>
              <circle cx="392" cy="468" r="26" fill="var(--text)"></circle>
              <circle cx="392" cy="468" r="11" fill="var(--surface)"></circle>
              {/* chassis */}
              <rect x="262" y="396" width="170" height="58" rx="12"
                fill="var(--surface)" stroke="var(--border)" stroke-width="2"></rect>
              <rect x="262" y="396" width="170" height="16" rx="8" fill="var(--brand)"></rect>
              {/* sensor mast + head */}
              <rect x="292" y="300" width="14" height="100" rx="6" fill="var(--text)" opacity="0.85"></rect>
              <rect x="262" y="266" width="92" height="44" rx="10"
                fill="var(--surface)" stroke="var(--border)" stroke-width="2"></rect>
              <circle cx="288" cy="288" r="13" fill="var(--brand)"></circle>
              <circle cx="288" cy="288" r="5" fill="var(--surface)"></circle>
              <circle cx="330" cy="288" r="8" fill="var(--accent)"></circle>
              {/* 6-axis arm: base -> shoulder -> elbow -> wrist -> gripper */}
              <g fill="none" stroke="var(--text)" stroke-width="13" stroke-linecap="round" stroke-linejoin="round">
                <path d="M360 398 L360 352"></path>
                <path d="M360 352 L452 322"></path>
                <path d="M452 322 L548 356"></path>
              </g>
              {/* joints */}
              <g fill="var(--brand)" stroke="var(--surface)" stroke-width="3">
                <circle cx="360" cy="398" r="12"></circle>
                <circle cx="360" cy="352" r="10"></circle>
                <circle cx="452" cy="322" r="10"></circle>
                <circle cx="548" cy="356" r="9"></circle>
              </g>
              {/* gripper reaching the detected tomato */}
              <g stroke="var(--text)" stroke-width="6" stroke-linecap="round" fill="none">
                <path d="M548 356 L578 344"></path>
                <path d="M578 344 L596 336 M578 344 L596 352"></path>
              </g>
            </g>
            {/* vision detection overlays */}
            <g fill="none" stroke="var(--brand)" stroke-width="2.5" stroke-dasharray="6 5">
              <rect x="598" y="338" width="30" height="30" rx="3"></rect>
              <rect x="574" y="378" width="30" height="30" rx="3"></rect>
            </g>
            <g font-family="monospace" font-size="13" fill="var(--brand)" font-weight="700">
              <text x="598" y="332">0.98</text>
              <text x="574" y="372">0.96</text>
            </g>
          </svg>
        </div>
        <p class="mt-3 text-center font-mono text-xs text-muted">{t("hero.fallback")}</p>
      </div>
    </Reveal>
  </div>
</section>
