---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const repo = "https://github.com/meviza/E-Farm-Autonomous-Harvesting-Robot";

const cards = [
  { title: t("tech.cards.visionTitle"), body: t("tech.cards.visionBody"), tag: "YOLOv8" },
  { title: t("tech.cards.lidarTitle"), body: t("tech.cards.lidarBody"), tag: "RealSense" },
  { title: t("tech.cards.armTitle"), body: t("tech.cards.armBody"), tag: "PAROL6" },
  { title: t("tech.cards.rosTitle"), body: t("tech.cards.rosBody"), tag: "ROS 2" },
  { title: t("tech.cards.bmsTitle"), body: t("tech.cards.bmsBody"), tag: "foxBMS" },
  { title: t("tech.cards.fleetTitle"), body: t("tech.cards.fleetBody"), tag: "MQTT" },
];

const foundations = [
  { label: "Ultralytics YOLOv8", href: "https://github.com/ultralytics/ultralytics" },
  { label: "PAROL6", href: "https://github.com/PCrnjak/PAROL6-Desktop-robot-arm" },
  { label: "MoveIt 2", href: "https://moveit.ai/" },
  { label: "Intel RealSense", href: "https://www.intelrealsense.com/" },
  { label: "foxBMS", href: "https://foxbms.org/" },
  { label: "ROS 2", href: "https://docs.ros.org/en/humble/" },
];
---

<section id="technology" class="scroll-mt-20 border-b border-border bg-bg-elevated">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("tech.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("tech.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("tech.lead")}</p>
    </Reveal>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        cards.map((c, i) => (
          <Reveal client:visible delay={(i % 3) * 0.06}>
            <div class="h-full rounded-2xl border border-border bg-surface p-6 shadow-[var(--shadow)] transition-colors hover:border-brand">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-semibold tracking-tight">{c.title}</h3>
                <span class="rounded-full bg-brand-soft px-2.5 py-0.5 font-mono text-xs text-brand-strong">
                  {c.tag}
                </span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-muted">{c.body}</p>
            </div>
          </Reveal>
        ))
      }
    </div>

    <Reveal client:visible>
      <div class="mt-10 rounded-2xl border border-border bg-surface p-6 shadow-[var(--shadow)]">
        <p class="text-sm font-medium text-text">{t("tech.foundations")}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            foundations.map((f) => (
              <a
                href={f.href}
                target="_blank"
                rel="noopener"
                class="rounded-full border border-border bg-bg px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:border-brand hover:text-brand"
              >
                {f.label}
              </a>
            ))
          }
        </div>
        <a
          href={repo}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand hover:text-brand-strong"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.39-5.25 5.67.42.36.79 1.08.79 2.18v3.23c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/></svg>
          {t("tech.repo")}
        </a>
      </div>
    </Reveal>
  </div>
</section>
