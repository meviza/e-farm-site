---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";
import { references } from "../../data/references";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="references" class="scroll-mt-20 border-b border-border bg-bg">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("refs.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("refs.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("refs.lead")}</p>
    </Reveal>

    <Reveal client:visible>
      <ol class="mt-10 space-y-4">
        {
          references.map((r, i) => (
            <li class="flex gap-4 rounded-2xl border border-border bg-surface p-5 shadow-[var(--shadow)]">
              <span class="font-mono text-sm font-semibold text-brand">[{i + 1}]</span>
              <p class="text-sm leading-relaxed text-muted">
                <span class="font-medium text-text">{r.authors}</span> ({r.year}).{" "}
                <span class="italic">{r.title}.</span> {r.venue}.{" "}
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener"
                  class="break-all font-mono text-brand hover:text-brand-strong hover:underline"
                >
                  {r.url}
                </a>
              </p>
            </li>
          ))
        }
      </ol>
    </Reveal>
  </div>
</section>
