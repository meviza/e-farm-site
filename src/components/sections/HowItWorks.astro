---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Inline lucide-style SVG paths per step.
const steps = [
  {
    title: t("how.steps.detectTitle"),
    body: t("how.steps.detectBody"),
    icon: '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
  },
  {
    title: t("how.steps.localizeTitle"),
    body: t("how.steps.localizeBody"),
    icon: '<path d="M12 2v4M12 18v4M2 12h4M18 12h4"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="9"/>',
  },
  {
    title: t("how.steps.graspTitle"),
    body: t("how.steps.graspBody"),
    icon: '<path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>',
  },
  {
    title: t("how.steps.depositTitle"),
    body: t("how.steps.depositBody"),
    icon: '<path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/>',
  },
];
---

<section id="how" class="scroll-mt-20 border-b border-border bg-bg">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("how.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("how.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("how.lead")}</p>
    </Reveal>

    <div class="relative mt-14">
      <!-- connecting line on large screens -->
      <div
        class="pointer-events-none absolute left-0 right-0 top-7 hidden h-px bg-border lg:block"
        aria-hidden="true"
      >
      </div>
      <ol class="relative grid gap-8 lg:grid-cols-4">
        {
          steps.map((s, i) => (
            <Reveal client:visible delay={i * 0.08}>
              <li class="relative flex flex-col items-start">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-border bg-surface text-brand shadow-[var(--shadow)]">
                  <svg
                    class="h-6 w-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={s.icon}
                  />
                </div>
                <h3 class="mt-5 text-lg font-semibold tracking-tight">{s.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{s.body}</p>
              </li>
            </Reveal>
          ))
        }
      </ol>
    </div>
  </div>
</section>
