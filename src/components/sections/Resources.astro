---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const dl = (file: string) => `${base}/downloads/${file}`;

const items = [
  { label: t("resources.items.whitepaper"), file: "whitepaper.pdf", ready: false },
  { label: t("resources.items.datasheet"), file: "datasheet.pdf", ready: false },
  { label: t("resources.items.pressKit"), file: "press-kit.zip", ready: false },
  { label: t("resources.items.termSheet"), file: "term-sheet.pdf", ready: false },
  { label: t("resources.items.parol6"), file: "parol6-manual.pdf", ready: false },
];
---

<section class="border-b border-border bg-bg">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("resources.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("resources.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("resources.lead")}</p>
    </Reveal>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item, i) => (
          <Reveal client:visible delay={(i % 3) * 0.06}>
            <a
              href={dl(item.file)}
              class="group flex h-full items-center justify-between gap-4 rounded-2xl border border-border bg-surface p-5 shadow-[var(--shadow)] transition-colors hover:border-brand"
            >
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-soft text-brand">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                </span>
                <div>
                  <div class="text-sm font-semibold text-text">{item.label}</div>
                  <div class="font-mono text-xs text-muted">{item.file}</div>
                </div>
              </div>
              <span
                class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${
                  item.ready ? "bg-brand-soft text-brand-strong" : "bg-surface-2 text-muted"
                }`}
              >
                {item.ready ? t("resources.ready") : t("resources.soon")}
              </span>
            </a>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
