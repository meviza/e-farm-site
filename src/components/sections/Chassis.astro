---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const points = [t("chassis.point1"), t("chassis.point2"), t("chassis.point3")];
---

<section class="border-b border-border bg-bg-elevated">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <Reveal client:visible delay={0.1}>
        <div class="order-2 rounded-2xl border border-border bg-surface p-8 shadow-[var(--shadow)] lg:order-1">
          <svg viewBox="0 0 400 200" class="w-full" role="img" aria-label={t("chassis.diagramAlt")}>
            <!-- ground -->
            <path d="M10 170 H390" stroke="var(--border)" stroke-width="2" />
            <!-- rocker body -->
            <rect x="120" y="70" width="160" height="44" rx="10" fill="var(--surface-2)" stroke="var(--brand)" stroke-width="1.5" />
            <text x="200" y="97" text-anchor="middle" fill="var(--text)" font-size="11" font-weight="600">compute · battery · arm</text>
            <!-- rocker links -->
            <path d="M150 100 L90 150" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" />
            <path d="M250 100 L310 150" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" />
            <path d="M150 100 L210 150" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" />
            <path d="M250 100 L190 150" stroke="var(--brand)" stroke-width="3" stroke-linecap="round" />
            <!-- wheels -->
            {
              [90, 190, 210, 310].map((cx) => (
                <g>
                  <circle cx={cx} cy="158" r="16" fill="var(--bg)" stroke="var(--text)" stroke-width="2" />
                  <circle cx={cx} cy="158" r="5" fill="var(--brand)" />
                </g>
              ))
            }
            <text x="200" y="194" text-anchor="middle" fill="var(--text-muted)" font-size="11" font-family="monospace">rocker-differential</text>
          </svg>
        </div>
      </Reveal>

      <Reveal client:visible>
        <div class="order-1 lg:order-2">
          <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
            {t("chassis.kicker")}
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("chassis.title")}</h2>
          <p class="mt-4 text-lg leading-relaxed text-muted">{t("chassis.lead")}</p>
          <ul class="mt-6 space-y-3">
            {
              points.map((p) => (
                <li class="flex gap-3 text-sm text-text">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  <span class="leading-relaxed">{p}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </Reveal>
    </div>
  </div>
</section>
