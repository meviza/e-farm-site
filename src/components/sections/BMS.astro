---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const points = [t("bms.point1"), t("bms.point2"), t("bms.point3")];
---

<section class="border-b border-border bg-bg">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <Reveal client:visible>
        <div>
          <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
            {t("bms.kicker")}
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("bms.title")}</h2>
          <p class="mt-4 text-lg leading-relaxed text-muted">{t("bms.lead")}</p>
          <ul class="mt-6 space-y-3">
            {
              points.map((p) => (
                <li class="flex gap-3 text-sm text-text">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  <span class="leading-relaxed">{p}</span>
                </li>
              ))
            }
          </ul>
          <p class="mt-6 font-mono text-xs text-muted">{t("bms.attribution")}</p>
        </div>
      </Reveal>

      <Reveal client:visible delay={0.1}>
        <div class="rounded-2xl border border-border bg-surface p-8 shadow-[var(--shadow)]">
          <svg viewBox="0 0 400 180" class="w-full" role="img" aria-label="Diagram: LiFePO4 cells feeding an ESP32 BMS that emits telemetry">
            <!-- cells -->
            <g>
              {
                [0, 1, 2, 3].map((i) => (
                  <rect x={20 + i * 26} y="60" width="20" height="60" rx="3" fill="var(--brand-soft)" stroke="var(--brand)" stroke-width="1.5" />
                ))
              }
              <text x="72" y="145" text-anchor="middle" fill="var(--text-muted)" font-size="11" font-family="monospace">{t("bms.diagram.cells")}</text>
            </g>
            <!-- arrow -->
            <path d="M132 90 H170" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arrow)" />
            <!-- BMS -->
            <rect x="172" y="62" width="76" height="56" rx="8" fill="var(--surface-2)" stroke="var(--brand)" stroke-width="1.5" />
            <text x="210" y="86" text-anchor="middle" fill="var(--text)" font-size="11" font-weight="600">ESP32</text>
            <text x="210" y="102" text-anchor="middle" fill="var(--text-muted)" font-size="10" font-family="monospace">BMS</text>
            <!-- arrow -->
            <path d="M250 90 H300" stroke="var(--text-muted)" stroke-width="1.5" marker-end="url(#arrow)" />
            <!-- telemetry -->
            <circle cx="338" cy="90" r="28" fill="var(--accent-soft)" stroke="var(--accent)" stroke-width="1.5" />
            <path d="M324 90 l8 8 l16 -18" stroke="var(--accent)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <text x="338" y="150" text-anchor="middle" fill="var(--text-muted)" font-size="11" font-family="monospace">{t("bms.diagram.telemetry")}</text>
            <defs>
              <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                <path d="M0 0 L6 3 L0 6 z" fill="var(--text-muted)" />
              </marker>
            </defs>
          </svg>
        </div>
      </Reveal>
    </div>
  </div>
</section>
