---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const disciplines = [
  { label: t("team.disciplines.cv"), icon: "👁️" },
  { label: t("team.disciplines.robotics"), icon: "🦾" },
  { label: t("team.disciplines.embedded"), icon: "🔌" },
  { label: t("team.disciplines.mechanical"), icon: "⚙️" },
  { label: t("team.disciplines.software"), icon: "💻" },
];
---

<section class="border-b border-border bg-bg-elevated">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("team.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("team.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("team.lead")}</p>
    </Reveal>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {
        disciplines.map((d, i) => (
          <Reveal client:visible delay={i * 0.05}>
            <div class="flex h-full flex-col items-center gap-3 rounded-2xl border border-border bg-surface p-6 text-center shadow-[var(--shadow)]">
              <span class="text-3xl" aria-hidden="true">{d.icon}</span>
              <span class="text-sm font-medium text-text">{d.label}</span>
            </div>
          </Reveal>
        ))
      }
    </div>

    <Reveal client:visible>
      <p class="mt-10 max-w-2xl text-sm italic leading-relaxed text-muted">{t("team.note")}</p>
    </Reveal>
  </div>
</section>
