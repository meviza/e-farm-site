---
import { useTranslations, type Lang } from "../../i18n/ui";
import Reveal from "../Reveal.tsx";
import { tiers } from "../../data/tiers";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const backerkit = "https://backerkit.com";
---

<section id="pledge" class="scroll-mt-20 border-b border-border bg-bg-elevated">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <Reveal client:visible>
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-brand">
        {t("tiers.kicker")}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{t("tiers.title")}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">{t("tiers.lead")}</p>
    </Reveal>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        tiers.map((tier, i) => (
          <Reveal client:visible delay={(i % 3) * 0.06}>
            <div
              class={`flex h-full flex-col rounded-2xl border p-6 shadow-[var(--shadow)] ${
                tier.featured ? "border-brand bg-surface ring-1 ring-brand" : "border-border bg-surface"
              }`}
            >
              <div class="flex items-center justify-between gap-2">
                <h3 class="text-lg font-semibold tracking-tight">{tier.name}</h3>
                {tier.limit && (
                  <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-accent">
                    {tier.limit}
                  </span>
                )}
              </div>
              <div class="mt-4 text-3xl font-extrabold tracking-tight text-text">{tier.price}</div>
              <ul class="mt-5 flex-1 space-y-2.5">
                {tier.includes.map((inc) => (
                  <li class="flex gap-2.5 text-sm text-muted">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="leading-relaxed">{inc}</span>
                  </li>
                ))}
              </ul>
              <a
                href={backerkit}
                target="_blank"
                rel="noopener"
                class={`mt-6 inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand ${
                  tier.featured
                    ? "bg-brand text-white hover:bg-brand-strong"
                    : "border border-border bg-bg text-text hover:bg-surface-2"
                }`}
              >
                {t("tiers.cta")}
              </a>
            </div>
          </Reveal>
        ))
      }
    </div>

    <Reveal client:visible>
      <p class="mt-10 max-w-3xl rounded-2xl border border-border bg-surface p-5 text-sm leading-relaxed text-muted shadow-[var(--shadow)]">
        {t("tiers.termSheet")}
      </p>
    </Reveal>
  </div>
</section>
